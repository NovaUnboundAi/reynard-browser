+static already_AddRefed<MacIOSurface> LookupSurface(
+    const SurfaceDescriptorMacIOSurface& aDescriptor) {
+  MacIOSurface::AllowAlpha allowAlpha = aDescriptor.isOpaque()
+                                            ? MacIOSurface::AllowAlpha::No
+                                            : MacIOSurface::AllowAlpha::Yes;
+  CFTypeRefPtr<IOSurfaceRef> surfaceRef =
+      aDescriptor.surfacePort().GetSurface();
+  if (surfaceRef) {
+    RefPtr<MacIOSurface> surface =
+        new MacIOSurface(std::move(surfaceRef), aDescriptor.yUVColorSpace(),
+                         aDescriptor.transferFunction(), allowAlpha);
+    return surface.forget();
+  }
+
+  return MacIOSurface::LookupSurface(
+      aDescriptor.surfaceId(), aDescriptor.yUVColorSpace(),
+      aDescriptor.transferFunction(), allowAlpha);
+}
