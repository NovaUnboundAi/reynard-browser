+static bool PostScriptNamesMatch(CGFontRef aFont, CFStringRef aRequestedName) {
+  AutoRelease<CFStringRef> cgName(CGFontCopyPostScriptName(aFont));
+  AutoRelease<CTFontRef> ctFont(
+      cgName ? CTFontCreateWithGraphicsFont(aFont, 0.0, nullptr, nullptr)
+             : nullptr);
+  AutoRelease<CFStringRef> ctName(ctFont ? CTFontCopyPostScriptName(ctFont)
+                                         : nullptr);
+  return ctName &&
+         CFStringCompare(cgName, aRequestedName, 0) == kCFCompareEqualTo &&
+         CFStringCompare(ctName, aRequestedName, 0) == kCFCompareEqualTo;
+}
+
+static already_AddRefed<UnscaledFont> CreateSystemUIUnscaledFont(
+    uint32_t aSystemFontTraits) {
+  AutoRelease<CTFontRef> systemFont(
+      CTFontCreateUIFontForLanguage(kCTFontUIFontSystem, 0.0, nullptr));
+  if (!systemFont) {
+    gfxWarning() << "Failed creating system UI CTFont.";
+    return nullptr;
+  }
+
+  CTFontSymbolicTraits traitMask = kCTFontTraitItalic | kCTFontTraitBold |
+                                   kCTFontTraitCondensed | kCTFontTraitExpanded;
+  CTFontSymbolicTraits traitValue =
+      static_cast<CTFontSymbolicTraits>(aSystemFontTraits & traitMask);
+  if (traitValue) {
+    systemFont = CTFontCreateCopyWithSymbolicTraits(systemFont, 0.0, nullptr,
+                                                    traitValue, traitMask);
+    if (!systemFont) {
+      gfxWarning() << "Failed applying system UI font traits.";
+      return nullptr;
+    }
+  }
+
+  AutoRelease<CTFontDescriptorRef> descriptor(
+      CTFontCopyFontDescriptor(systemFont));
+  AutoRelease<CGFontRef> cgFont(CTFontCopyGraphicsFont(systemFont, nullptr));
+  if (!descriptor || !cgFont) {
+    gfxWarning() << "Failed copying system UI font descriptor or CGFont.";
+    return nullptr;
+  }
+
+  RefPtr<UnscaledFont> unscaledFont = new UnscaledFontMac(
+      descriptor, cgFont, false, UnscaledFont::DescriptorProvenance::SystemUI,
+      aSystemFontTraits);
+  return unscaledFont.forget();
+}
